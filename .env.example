HTTP_ADDR=:8080
SQLITE_PATH=./data/certschedule.db

JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=24h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# 32 raw bytes for AES-256-GCM, e.g. generate with: openssl rand -hex 32 | cut -c1-32
ENCRYPTION_KEY=00000000000000000000000000000000

CERTBOT_BINARY=certbot
CERTBOT_DATA_DIR=./data/certbot
CERTBOT_STAGING=true
CERTBOT_DRY_RUN=false
CERTBOT_WEBROOT=./data/webroot
CERTBOT_EMAIL=admin@example.com

SCHEDULER_INTERVAL=12h

# Optional: path to kubeconfig when running outside a cluster
KUBECONFIG=
